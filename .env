# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  KONFIGURASI BOT TRADING — GROQ EDITION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 1. Dapatkan dari @BotFather di Telegram
#    → /newbot → ikuti instruksi → copy token
TELEGRAM_BOT_TOKEN=token_dari_botfather_disini

# 2. Dapatkan dari https://console.groq.com
#    → Daftar GRATIS → API Keys → Create API Key
#    Format: gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxx
